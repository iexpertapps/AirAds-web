# =============================================================================
# AirAd — Root .gitignore
# =============================================================================

# Environment files — NEVER commit secrets
.env
.env.local
.env.*.local
*.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/
.eggs/
.venv/
venv/
env/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml

# pytest
.pytest_cache/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
dist-ssr/

# IDE
.vscode/
.idea/
*.swp
*.swo
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln
.DS_Store

# Docker
*.pid

# Temporary files
*.tmp
*.bak
*.orig
