# =============================================================================
# AirAd Backend — Environment Variables
# Zero literal placeholder values — only generation instructions.
# =============================================================================

# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Generate 32-byte base64 key: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# PostGIS connection string — format: postgis://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgis://airaad:airaad@localhost:5432/airaad_db

# Redis — used for cache and Celery broker/result backend
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AWS S3 — create an IAM user with S3 permissions, generate access keys in AWS Console
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Google Places API — https://console.cloud.google.com → APIs & Services → Credentials
# Enable "Places API" on your GCP project first
GOOGLE_PLACES_API_KEY=

# Stripe — https://dashboard.stripe.com/apikeys
# Secret key: sk_test_... (test) or sk_live_... (production)
STRIPE_SECRET_KEY=
# Publishable key: pk_test_... (frontend only, not used in backend)
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret: whsec_... (from Stripe Dashboard → Webhooks → Signing secret)
STRIPE_WEBHOOK_SECRET=
# Price IDs for each subscription tier — create Products + Prices in Stripe Dashboard
STRIPE_PRICE_GOLD=
STRIPE_PRICE_DIAMOND=
STRIPE_PRICE_PLATINUM=

# Number of trusted reverse proxies (default 1 for nginx)
NUM_PROXIES=1

# CORS allowed origins (comma-separated) — set in production
CORS_ALLOWED_ORIGINS=

# Twilio SMS — https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Firebase Cloud Messaging — service account JSON (base64 encoded or file path)
FIREBASE_CREDENTIALS_JSON=

# Sentry error tracking — https://sentry.io
SENTRY_DSN=

# OTP Manual Mode — set a fixed 6-digit OTP code for dev/testing without Twilio.
# Clear this (set to empty) when Twilio is configured for real SMS delivery.
MANUAL_OTP_CODE=005261

# JWT token lifetimes
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

# Stripe Silver tier price ID (free tier, optional)
STRIPE_SILVER_PRICE_ID=
